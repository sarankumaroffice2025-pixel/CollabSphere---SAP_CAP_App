### Update Project Approver Details
POST {{baseurl}}/updateProjectApprover
Content-Type: application/json

{
  "data": {
    "projectID": "50642614-7d40-494b-8ffa-504a753efcee",
    "approversData": [
      {
        "approverID": "cd180778-0355-447f-b73d-a5da05ff7dd3",
        "approvalStatus": "approved",
        "comment": "Approved the project details"
      },
      {
        "approverID": "56a74b49-2ef9-4b33-9e1b-6baae5bdf54e",
        "approvalStatus": "cancelled",
        "comment": "Rejected the project due to budget concerns"
      }
    ]
  }
}


